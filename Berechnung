<!DOCTYPE html>
<html lang="de">
<head>

<meta charset="UTF-8">
<title>Zahnrad Simulation</title>

<style>

body{
font-family:Arial;
background:#f1f5f9;
margin:0;
display:flex;
height:100vh;
}

.sidebar{
width:320px;
background:white;
padding:20px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
overflow:auto;
}

h1{
font-size:22px;
}

.control{
margin-bottom:20px;
}

label{
display:block;
margin-bottom:5px;
}

.value{
font-weight:bold;
}

button{
padding:10px;
margin-top:5px;
cursor:pointer;
}

.main{
flex:1;
display:flex;
justify-content:center;
align-items:center;
}

svg{
background:white;
border-radius:10px;
}

</style>

</head>

<body>

<div class="sidebar">

<h1>Zahnrad Simulation</h1>

<div class="control">
<label>Zähne Z1</label>
<input type="range" min="10" max="60" value="20" id="z1">
<span class="value" id="z1v">20</span>
</div>

<div class="control">
<label>Zähne Z2</label>
<input type="range" min="10" max="60" value="40" id="z2">
<span class="value" id="z2v">40</span>
</div>

<div class="control">
<label>Modul</label>
<input type="range" min="5" max="20" value="10" id="module">
<span class="value" id="modulev">10</span>
</div>

<div class="control">
<label>Drehzahl (U/min)</label>
<input type="range" min="5" max="100" value="20" id="rpm">
<span class="value" id="rpmv">20</span>
</div>

<button onclick="toggle()">Start / Stop</button>
<button onclick="reverse()">Richtung wechseln</button>

<hr>

<h3>Berechnung</h3>

<p>Übersetzung: <span id="ratio"></span></p>
<p>Abtriebsdrehzahl: <span id="rpmout"></span></p>

</div>


<div class="main">

<svg width="800" height="400" viewBox="-200 -200 800 400">

<circle id="gear1" cx="0" cy="0" r="100" fill="#e2e8f0" stroke="#334155" stroke-width="4"/>
<circle id="gear2" cx="300" cy="0" r="200" fill="#fde68a" stroke="#d97706" stroke-width="4"/>

<circle cx="0" cy="0" r="8" fill="black"/>
<circle cx="300" cy="0" r="8" fill="black"/>

</svg>

</div>


<script>

let z1=20
let z2=40
let module=10
let rpm=20

let playing=true
let direction=1

let angle=0

const gear1=document.getElementById("gear1")
const gear2=document.getElementById("gear2")

function update(){

z1=parseInt(document.getElementById("z1").value)
z2=parseInt(document.getElementById("z2").value)
module=parseInt(document.getElementById("module").value)
rpm=parseInt(document.getElementById("rpm").value)

document.getElementById("z1v").innerText=z1
document.getElementById("z2v").innerText=z2
document.getElementById("modulev").innerText=module
document.getElementById("rpmv").innerText=rpm

let d1=z1*module
let d2=z2*module

gear1.setAttribute("r",d1/2)
gear2.setAttribute("r",d2/2)
gear2.setAttribute("cx",d1/2+d2/2)

let ratio=z2/z1
let rpmout=rpm/ratio

document.getElementById("ratio").innerText="1 : "+ratio.toFixed(2)
document.getElementById("rpmout").innerText=rpmout.toFixed(1)+" U/min"

}

document.querySelectorAll("input").forEach(e=>e.oninput=update)

function toggle(){
playing=!playing
}

function reverse(){
direction*=-1
}

function animate(){

if(playing){

let speed=rpm*6*direction

angle+=speed*0.016

gear1.setAttribute("transform","rotate("+angle+")")

let a2=-angle*(z1/z2)

gear2.setAttribute("transform","rotate("+a2+" "+gear2.getAttribute("cx")+" 0)")

}

requestAnimationFrame(animate)

}

update()
animate()

</script>

</body>
</html>
